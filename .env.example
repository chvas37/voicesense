APP_NAME=voicesense
ENVIRONMENT=development

# Frontend — leave unset for local Next dev (uses /api proxy). Set for production or direct API calls.
# NEXT_PUBLIC_API_BASE_URL=http://localhost:8080

# Common services
DATABASE_URL=postgresql://voicesense:voicesense@postgres:5432/voicesense
REDIS_URL=redis://redis:6379/0
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
INTERNAL_SERVICE_TOKEN=internal-dev-token

# JWT
JWT_SECRET=replace-with-strong-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXP_MINUTES=60
REFRESH_TOKEN_EXP_DAYS=14

# Internal service URLs
AUTH_SERVICE_URL=http://auth-service:8000
ROOM_SERVICE_URL=http://room-service:8000
CHAT_SERVICE_URL=http://chat-service:8000
MEDIA_SERVICE_URL=http://media-service:8000

# LiveKit
LIVEKIT_WS_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret
